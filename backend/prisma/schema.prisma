generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String        @id @default(cuid())
  externalRef   String        @unique
  balanceMinor  String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bets          Bet[]
  cashouts      Cashout[]
  ledgerEntries LedgerEntry[]
}

model GameRound {
  id               String      @id @default(cuid())
  gameKey          String
  status           String
  bettingOpenAt    DateTime
  bettingCloseAt   DateTime
  startedAt        DateTime?
  crashedAt        DateTime?
  settledAt        DateTime?
  crashMultiplier  String?
  rngSeedRef       String?
  serverSeedHash   String?
  fairnessVersion  String
  configSnapshot   Json
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  bets             Bet[]
  cashouts         Cashout[]

  @@index([gameKey, status])
  @@index([createdAt])
}

model Bet {
  id                String      @id @default(cuid())
  userId            String
  roundId           String
  amountMinor       String
  placedAt          DateTime
  status            String
  cashoutMultiplier String?
  payoutAmountMinor String?
  rejectionReason   String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id])
  round             GameRound   @relation(fields: [roundId], references: [id])
  cashout           Cashout?

  @@index([userId, roundId])
  @@index([roundId, status])
}

model Cashout {
  id                String      @id @default(cuid())
  betId             String      @unique
  userId            String
  roundId           String
  cashoutMultiplier String
  payoutAmountMinor String
  requestedAt       DateTime
  processedAt       DateTime
  createdAt         DateTime    @default(now())
  user              User        @relation(fields: [userId], references: [id])
  round             GameRound   @relation(fields: [roundId], references: [id])
  bet               Bet         @relation(fields: [betId], references: [id])

  @@index([roundId])
  @@index([userId, roundId])
}

model LedgerEntry {
  id                String      @id @default(cuid())
  userId            String
  roundId           String?
  betId             String?
  cashoutId         String?
  entryType         String
  amountMinor       String
  balanceBeforeMinor String
  balanceAfterMinor  String
  idempotencyKey    String      @unique
  createdAt         DateTime    @default(now())
  user              User        @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([roundId])
}
